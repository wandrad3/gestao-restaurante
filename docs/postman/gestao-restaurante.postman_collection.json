  },
  "auth": {
    "type": "noauth"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const expectedStatusByMethod = {",
          "  GET: 200,",
          "  POST: 201,",
          "  PUT: 200,",
          "  PATCH: 204,",
          "  DELETE: 204",
          "};",
          "",
          "const expectedStatus = expectedStatusByMethod[pm.request.method];",
          "if (expectedStatus) {",
          "  pm.test(`Status ${expectedStatus}`, function () {",
          "    pm.response.to.have.status(expectedStatus);",
          "  });",
          "}",
          "",
          "pm.test('Tempo de resposta menor que 2 segundos', function () {",
          "  pm.expect(pm.response.responseTime).to.be.below(2000);",
          "});",
          "",
          "const contentType = pm.response.headers.get('Content-Type') || '';",
          "if (contentType.includes('application/json') && pm.response.text()) {",
          "  pm.test('Resposta contém JSON válido', function () {",
          "    pm.expect(function () { pm.response.json(); }).not.to.throw();",
          "  });",
          "}",
          "",
          "if (pm.request.method === 'POST' && pm.response.code === 201) {",
          "  const response = pm.response.json();",
          "  const path = pm.request.url.getPath();",
          "  const idVariableByPath = {",
          "    '/api/v1/user-types': 'user_type_id',",
          "    '/api/v1/users': 'user_id',",
          "    '/api/v1/restaurants': 'restaurant_id',",
          "    '/api/v1/menu-items': 'menu_item_id'",
          "  };",
          "  const variableName = idVariableByPath[path];",
          "  if (variableName && response.id) {",
          "    pm.collectionVariables.set(variableName, response.id);",
          "    if (pm.environment.name) {",
          "      pm.environment.set(variableName, response.id);",
          "    }",
          "    console.log(`${variableName} salvo: ${response.id}`);",
          "  }",
          "}"
        ]
      }
    }
  ],
